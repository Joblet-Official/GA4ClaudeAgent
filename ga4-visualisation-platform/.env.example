# Copy to .env.local and fill in real values. Never commit .env.local.

# Per-brain provider/model selection. Format:
#   LLM_PROVIDER_<BRAIN>  → overrides LLM_PROVIDER for that brain
#   LLM_MODEL_<BRAIN>     → overrides the provider's default model
# Supported providers: nvidia | groq | cerebras | together | gemini

LLM_PROVIDER=nvidia
LLM_PROVIDER_BRAIN2=cerebras
LLM_MODEL_BRAIN2=gpt-oss-120b
LLM_PROVIDER_BRAIN3=gemini
LLM_MODEL_BRAIN3=gemini-2.0-flash

# Provider-specific API keys — only those matching active providers need to be set.
NVIDIA_API_KEY=nvapi-...
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=csk-...
TOGETHER_API_KEY=...
GEMINI_API_KEY=AIzaSy...

# GA4
GA4_PROPERTY_ID=516147906
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
