# DeepSeek (Phase 1) — set these in Vercel (Alifya's Projects). NEVER commit real values.
#
# Two keys: Pro and Flash authenticate independently.
DEEPSEEK_PRO_API_KEY=nvapi-...
DEEPSEEK_FLASH_API_KEY=nvapi-...

# Optional — defaults shown. Override only if your endpoint/model ids differ.
# DEEPSEEK_BASE_URL=https://integrate.api.nvidia.com/v1
# DEEPSEEK_PRO_MODEL=deepseek-ai/deepseek-v4-pro
# DEEPSEEK_FLASH_MODEL=deepseek-ai/deepseek-v4-flash

# Per-brain routing to DeepSeek (set in Vercel to MIGRATE Brain 1-3).
# Brain 1 + Brain 2 -> Pro; Brain 3 -> Flash (escalates to Pro on failure via the orchestrator).
# LLM_PROVIDER_BRAIN1=deepseek_pro
# LLM_MODEL_BRAIN1=deepseek-ai/deepseek-v4-pro
# LLM_PROVIDER_BRAIN2=deepseek_pro
# LLM_MODEL_BRAIN2=deepseek-ai/deepseek-v4-pro
# LLM_PROVIDER_BRAIN3=deepseek_flash
# LLM_MODEL_BRAIN3=deepseek-ai/deepseek-v4-flash
