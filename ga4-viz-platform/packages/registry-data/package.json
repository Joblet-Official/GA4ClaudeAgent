    "./viz-registry": "./viz-registry.json",
    "./trigger-expressions": "./trigger-expressions.json",
    "./tool-boundaries": "./tool-boundaries.json",
    "./state-machine": "./state-machine.json"
  },
  "files": [
    "catalog.json",
    "defaults.json",
    "metric-ontology.json",
    "domain-profile.json",
    "block-pattern.json",
    "viz-registry.json",
    "trigger-expressions.json",
    "tool-boundaries.json",
